{
    "title": "BriefAIOutline",
    "type": "object",
    "required": ["konu", "strateji", "title_meta", "outline", "eeat", "schema_org", "faq", "qc"],
    "properties": {
      "konu": { "type": "string" },
      "strateji": {
        "type": "object",
        "required": ["intent", "tone", "uvp", "rekabet_ozeti", "hedef_anahtar", "ikincil_anahtarlar"],
        "properties": {
          "intent": { "type": "string", "enum": ["Informational","Transactional","Commercial","Navigational","Mixed"] },
          "tone": { "type": "string" },
          "uvp": { "type": "string", "minLength": 20 },
          "rekabet_ozeti": { "type": "string" },
          "hedef_anahtar": { "type": "string" },
          "ikincil_anahtarlar": { "type": "array", "items": { "type": "string" }, "minItems": 5, "maxItems": 12 }
        }
      },
      "title_meta": {
        "type": "object",
        "required": ["title_click","title_seo","meta"],
        "properties": {
          "title_click": { "type": "string", "minLength": 20 },
          "title_seo": { "type": "string", "minLength": 20 },
          "meta": { "type": "string", "maxLength": 155 }
        }
      },
      "outline": {
        "type": "object",
        "required": ["h1", "giris", "bolumler"],
        "properties": {
          "h1": { "type": "string" },
          "giris": { "type": "string" },
          "bolumler": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "object",
              "required": ["h2", "icerik_notu", "media", "kilit_bilgi", "alt"],
              "properties": {
                "h2": { "type": "string" },
                "icerik_notu": { "type": "string" },
                "media": { "type": "string", "description": "image/video suggestion + alt text idea" },
                "kilit_bilgi": { "type": "string" },
                "alt": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["h3", "icerik_notu"],
                    "properties": {
                      "h3": { "type": "string" },
                      "icerik_notu": { "type": "string" },
                      "hikaye_notu": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "eeat": {
        "type": "object",
        "required": ["yazar_onerisi","veri_kaynak_onerileri","entity_entegrasyonu","guncellik_plani"],
        "properties": {
          "yazar_onerisi": { "type": "string" },
          "veri_kaynak_onerileri": { "type": "array", "items": { "type": "string" }, "minItems": 3 },
          "entity_entegrasyonu": { "type": "array", "items": { "type": "string" } },
          "guncellik_plani": {
            "type": "object",
            "required": ["yillik_kontrol","veri_tazeleme"],
            "properties": {
              "yillik_kontrol": { "type": "string" },
              "veri_tazeleme": { "type": "string" }
            }
          }
        }
      },
      "schema_org": {
        "type": "object",
        "required": ["ana","destekleyici","gerekce"],
        "properties": {
          "ana": { "type": "string", "enum": ["Article","HowTo","FAQPage","Recipe","Product","TouristAttraction","Comparison","Guide"] },
          "destekleyici": { "type": "array", "items": { "type": "string" } },
          "gerekce": { "type": "string" }
        }
      },
      "faq": {
        "type": "array",
        "minItems": 8,
        "maxItems": 12,
        "items": {
          "type": "object",
          "required": ["soru","cevap"],
          "properties": {
            "soru": { "type": "string" },
            "cevap": { "type": "string" }
          }
        }
      },
      "qc": {
        "type": "object",
        "required": ["ozgunluk","baslik_giris","okunabilirlik","eeat","gorsel","linkleme","sss","dilbilgisi"],
        "properties": {
          "ozgunluk": { "type": "boolean" },
          "baslik_giris": { "type": "boolean" },
          "okunabilirlik": { "type": "boolean" },
          "eeat": { "type": "boolean" },
          "gorsel": { "type": "boolean" },
          "linkleme": { "type": "boolean" },
          "sss": { "type": "boolean" },
          "dilbilgisi": { "type": "boolean" }
        }
      }
    }
  }
  